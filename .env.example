# StartItUp.in — connect YOUR Supabase project (not the MCP-linked account).
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

# Project URL (safe for browser if you add client-side auth later)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon / publishable key (public, RLS-protected)
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only — never commit .env or expose these to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_SECRET=choose-a-strong-admin-password

# For npm run db:migrate / db:setup (pick ONE):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_ACCESS_TOKEN=your-personal-access-token
